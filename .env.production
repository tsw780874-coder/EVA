# ============================================
# EVA 生产部署环境变量（2GB 服务器极简版）
# 复制到服务器 /opt/eva/.env 并填入真实值
# ============================================

# --- JWT (生成命令: openssl rand -hex 32) ---
JWT_SECRET=change-me-to-a-random-64-char-string

# --- 默认 LLM 提供商 (deepseek / openai / groq / glm_flash / glm47_flash / ernie_speed / ernie35) ---
DEFAULT_LLM_PROVIDER=deepseek

# --- AI 模型 API Keys（至少配置一个）---
# Groq LPU (极速推理，推荐)
GROQ_API_KEY=gsk_xxx

# DeepSeek (管理员主力)
DEEPSEEK_API_KEY=sk-xxx

# OpenAI GPT-4o
OPENAI_API_KEY=sk-xxx

# 智谱 GLM-4-Flash (免费快速)
GLM_FLASH_API_KEY=xxx

# 智谱 GLM-4.7-Flash (最新快速)
GLM47_FLASH_API_KEY=xxx

# 百度 ERNIE-Speed (轻量快速)
ERNIE_SPEED_API_KEY=xxx

# 百度 ERNIE-3.5 (标准)
ERNIE35_API_KEY=xxx

# 火山引擎 Seedream (图像生成，可选)
SEEDREAM_API_KEY=xxx
